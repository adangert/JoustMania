# JoustMania Dashboard - Unified Reverse Proxy
# Caddy reverse proxy for all services
#
# Caddy automatically:
# - Handles proper header forwarding (Host, X-Forwarded-For, etc.)
# - Rewrites Location headers in redirects to prevent localhost issues
# - Supports WebSocket upgrades
# - Provides better subpath handling

:80 {
	# Root directory for static files
	root * /usr/share/caddy

	# Enable gzip compression
	encode gzip

	# =========================================
	# Connect-Web API (gRPC-Web proxy)
	# =========================================
	handle /joustmania* {
		reverse_proxy connect-proxy:8080 {
			# Enable immediate flushing for streaming support
			flush_interval -1
			# Extended timeout for long-running requests
			transport http {
				read_timeout 3600s
			}
		}
	}

	# =========================================
	# Observability Tools (reverse proxied)
	# =========================================

	# Jaeger UI
	handle_path /jaeger/* {
		reverse_proxy jaeger:16686
	}

	# Prometheus UI
	handle_path /prometheus/* {
		reverse_proxy prometheus:9090
	}

	# Grafana UI
	handle_path /grafana/* {
		reverse_proxy grafana:3000
	}

	# Loki API (for log queries)
	handle_path /loki/* {
		reverse_proxy loki:3100
	}

	# =========================================
	# Legacy WebUI (for backwards compatibility)
	# =========================================
	handle_path /legacy/* {
		reverse_proxy webui:80
	}

	# =========================================
	# Health check endpoint
	# =========================================
	handle /health {
		respond "OK" 200
	}

	# =========================================
	# Dashboard SPA
	# =========================================
	# Serve static files with caching for assets
	@assets {
		path /assets/*
	}
	handle @assets {
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	# SPA fallback - serve index.html for all other routes
	handle {
		try_files {path} /index.html
		file_server
	}
}
